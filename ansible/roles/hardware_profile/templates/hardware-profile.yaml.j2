apiVersion: infrastructure.opendatahub.io/v1
kind: HardwareProfile
metadata:
  name: nvidia-l4-profile
  namespace: redhat-ods-applications
  annotations:
    opendatahub.io/display-name: NVIDIA L4
    opendatahub.io/description: Hardware profile for NVIDIA L4 GPU nodes
    opendatahub.io/disabled: "false"
    opendatahub.io/managed: "false"
    opendatahub.io/dashboard-feature-visibility: '[]'
spec:
  identifiers:
    - displayName: CPU
      identifier: cpu
      resourceType: CPU
      defaultCount: 2
      minCount: 1
      maxCount: 8

    - displayName: Memory
      identifier: memory
      resourceType: Memory
      defaultCount: 8Gi
      minCount: 4Gi
      maxCount: 32Gi

    - displayName: NVIDIA GPU
      identifier: nvidia.com/gpu
      resourceType: Accelerator
      defaultCount: 1
      minCount: 1
      maxCount: 1

  nodeSelector:
    nvidia.com/gpu.present: "true"
    nvidia.com/gpu.product: NVIDIA-L4